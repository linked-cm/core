{
  "compilerOptions": {
    "sourceMap": true,
    "declaration": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "pretty": true,
    "target": "es6",
    "moduleResolution": "node",
    "types": ["node", "jest"],
    "baseUrl": "./",
    "paths": {
      "*": ["node_modules/@types/*", "../../node_modules/@types/*", "*"]
    }
  },
  "include": [
    "./src/**/*.ts"
  ],
  "exclude": [
    "./src/tests/**",
    "./src/test-helpers/**"
  ]
}
